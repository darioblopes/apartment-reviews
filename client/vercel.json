{
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "https://apartment-reviews.onrender.com/auth/$1"
    },
    {
      "source": "/apartments/(.*)",
      "destination": "https://apartment-reviews.onrender.com/apartments/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://apartment-reviews.onrender.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
